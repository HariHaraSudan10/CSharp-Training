@model Assessment1___Question2.Models.Movie
@{
    ViewBag.Title = "Edit";
}

<h2>Edit</h2>

@using (Html.BeginForm())
{
    @Html.HiddenFor(x => x.Mid)

    <p>Movie Name</p>
    @Html.TextBoxFor(x => x.Moviename)

    <p>Director Name</p>
    @Html.TextBoxFor(x => x.DirectorName)

    <p>Date Of Release</p>
    @Html.TextBoxFor(x => x.DateofRelease,
                     "{0:yyyy-MM-dd}",
                     new { type = "date" })

    <br />
    <br />

    <input type="submit" value="Update" />
}